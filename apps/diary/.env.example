# Edelmore Diary — environment variable template
#
#   cp .env.example .env
#   npm run dev
#
# Only DATABASE_URL is required. The transcription (Whisper) and narration
# (Kokoro TTS) services are optional, external homelab services — leave their
# URLs blank and the diary still works fully for typing and reading; only the
# voice features go quiet.
#
# There are no per-user PIN or session-secret variables: users are created the
# first time you visit /admin on a fresh database, and sessions are random
# tokens stored in the sessions table. Reset a PIN by visiting /settings (or
# editing the SQLite file directly).


# ─── Demo mode ────────────────────────────────────────────────────────────────
# When DEMO_MODE=true, unauthenticated visitors land on the public /welcome
# marketing page (the demo landing with the Taylor / 1313 credentials). Leave
# unset for normal household use — unauthenticated visitors go to /login.
DEMO_MODE=


# ─── Admin gate ───────────────────────────────────────────────────────────────
# PIN protecting the /admin accounts page (it is reachable before login).
# Leave blank to keep /admin open — useful only for first-run bootstrap;
# set a value before letting the household loose on the app.
ADMIN_PIN=


# ─── Timezone ─────────────────────────────────────────────────────────────────
# The diary's "today" is the household's wall-clock day. docker-compose.yml
# passes this into the container (defaults to America/New_York there); set it
# to your own zone. Harmless to leave unset for local npm-run-dev use — the
# dev server already runs in your machine's zone.
TZ=America/New_York


# ─── Database (required) ─────────────────────────────────────────────────────
# Local dev: relative path from repo root.
# Docker prod: overridden to /data/edelmore.db via container env.
DATABASE_URL=data/edelmore.db


# ─── Transcription / Whisper (optional) ──────────────────────────────────────
# Upstream WhisperX /asr endpoint. Leave blank to disable the mic button.
TRANSCRIPTION_URL=http://shingan.lan:9000/asr
# Optional bearer token sent to the upstream, if it requires one.
TRANSCRIPTION_API_KEY=


# ─── Narration / Kokoro TTS (optional) ───────────────────────────────────────
# Read-aloud service. Leave TTS_URL blank to disable read-aloud (the settings
# voice picker then falls back to the browser's built-in voices).
TTS_URL=http://shingan.lan:8880/dev/captioned_speech
TTS_VOICES_URL=http://shingan.lan:8880/v1/audio/voices
# Optional bearer token for the TTS upstream.
TTS_API_KEY=

# On-demand Kokoro lifecycle (optional).
#
# Fork path (preferred): set TTS_UNLOAD_URL to the /dev/unload endpoint exposed
# by sageframe-no-kaji/Kokoro-FastAPI (feature/model-unload). After
# KOKORO_IDLE_MINUTES of silence the shim POSTs to this URL to release GPU VRAM
# without stopping the container; the model reloads lazily on the next request.
# When TTS_UNLOAD_URL is set, DOCKER_API_URL and KOKORO_CONTAINER_NAME are ignored.
TTS_UNLOAD_URL=http://shingan.lan:8880/dev/unload
KOKORO_IDLE_MINUTES=10

# Legacy path: when TTS_UNLOAD_URL is blank, the shim manages the container
# directly via the Docker remote API — starting it on the first narration and
# stopping it after KOKORO_IDLE_MINUTES of silence.
DOCKER_API_URL=http://your-docker-host:2376
KOKORO_CONTAINER_NAME=svc-kokoro
