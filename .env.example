# Edelmore Diary — environment variables
# Copy to .env and fill in values before running

# Path to SQLite database file
# In Docker: lives inside the data/ volume mount
DATABASE_URL=/data/edelmore.db

# Full URL of the upstream Whisper transcription service /asr endpoint.
# Family deploy: shingan runs whisperx-asr-service.
# e.g., http://shingan:9000/asr or http://whisper.home.arpa:9000/asr
TRANSCRIPTION_URL=http://shingan:9000/asr

# Optional bearer token. Empty for the LAN service; populated for the
# future demo deploy that uses an API-keyed transcription provider.
TRANSCRIPTION_API_KEY=

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Kokoro-FastAPI TTS service (shingan.lan:8880 on the internal network).
# TTS_URL points at the captioned_speech endpoint (the one that returns word timings).
# TTS_VOICES_URL points at the voices catalog. If unset, the shim derives it from TTS_URL.
# TTS_API_KEY is optional; the LAN service needs none — set if the service is ever
# exposed outside the LAN with an API key.
TTS_URL=http://shingan.lan:8880/dev/captioned_speech
TTS_VOICES_URL=http://shingan.lan:8880/v1/audio/voices
TTS_API_KEY=

# Initial PINs for Iona and Isla (4-digit; used only on first start when the DB is empty)
# Change these before first production start. Reset at the SQLite level if forgotten.
IONA_PIN=1111
ISLA_PIN=2222
