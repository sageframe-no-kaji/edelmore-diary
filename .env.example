c# Edelmore Diary — environment variables
# Copy to .env and fill in values before running

# Path to SQLite database file
# In Docker: lives inside the data/ volume mount
DATABASE_URL=/data/edelmore.db

# URL of the Whisper transcription service on the homelab network
# e.g., http://whisper.home.arpa:9000 or http://whisper:9000 if on the same compose network
WHISPER_URL=http://whisper.home.example:9000

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=
